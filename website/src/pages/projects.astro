---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    name: 'Keyboard Helper',
    description: 'A desktop overlay that visualizes split and ergonomic keyboard layouts in real time.',
    href: 'https://github.com/maxistar/keyboard_helper',
  },
  {
    name: 'Voice Inbox',
    description: 'This local-first voice note transcription app: Android ready, iOS MVP in progress.',
    href: 'https://github.com/maxistar/Voice-Inbox',
  },
  {
    name: 'More projects',
    description: 'TODO: add more maintainer projects here as publication links become final.',
    href: '',
  },
];
---
<Layout title="Other Projects" description="Other projects by the Voice Inbox maintainer.">
  <style>
    .projects {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 18px;
    }
    .project-link {
      margin-top: 16px;
      font-weight: 800;
    }
  </style>

  <p class="eyebrow">Other projects</p>
  <h1>More tools from the maintainer.</h1>
  <p>
    A small place for related open-source projects. Entries are deliberately simple so links can be edited as projects move or launch.
  </p>

  <section class="projects">
    {projects.map((project) => (
      <article class="card">
        <h2>{project.name}</h2>
        <p>{project.description}</p>
        {project.href ? (
          <p class="project-link"><a href={project.href} target="_blank" rel="noopener">Open project</a></p>
        ) : (
          <p class="project-link">Link coming later</p>
        )}
      </article>
    ))}
  </section>
</Layout>
