---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    name: 'Simple Text Editor',
    description: 'A small Android app for editing plain text files, quick notes, and drafts on your device.',
    href: 'https://simpleditor.org/',
  },
  {
    name: 'GitSy',
    description: 'Sync a Notes Folder with Git',
    href: 'https://gitsy.de/',
  },
  {
    name: 'Watchface Fun',
    description: 'Functional Watchfaces for Meaningful Living',
    href: 'https://watchface.fun/',
  },
  {
    name: 'More projects',
    description: 'Browse more projects by the maintainer.',
    href: 'https://projects.maxistar.me/',
  },
];
---
<Layout title="Other Projects" description="Other projects by the Voice Inbox maintainer.">
  <style>
    .projects {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 18px;
    }
    .project-link {
      margin-top: 16px;
      font-weight: 800;
    }
  </style>

  <p class="eyebrow">Other projects</p>
  <h1>More tools from the maintainer.</h1>
  <p>
    A small place for related open-source projects. Entries are deliberately simple so links can be edited as projects move or launch.
  </p>

  <section class="projects">
    {projects.map((project) => (
      <article class="card">
        <h2>{project.name}</h2>
        <p>{project.description}</p>
        <p class="project-link"><a href={project.href} target="_blank" rel="noopener">Open project</a></p>
      </article>
    ))}
  </section>
</Layout>
